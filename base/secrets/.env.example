# =============================================================================
# SECRETS - solidarytech
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais (saem do
# `terraform output`, no repo hackathon-DCLT/infra):
#   cp .env.example .env
#
# Para aplicar no cluster:
#   bash apply-secrets.sh
#
# O arquivo .env é gitignored — nunca commite valores reais.
# =============================================================================

# --- ngo-service (Postgres) ---
# terraform output -json rds_endpoints | jq -r '.ngo'
NGO_RDS_ENDPOINT=<NGO_RDS_ENDPOINT>
# senha definida em infra/terraform.tfvars (db_password)
NGO_DB_PASSWORD=<NGO_DB_PASSWORD>

# --- donation-service (Postgres) ---
# terraform output -json rds_endpoints | jq -r '.donation'
DONATION_RDS_ENDPOINT=<DONATION_RDS_ENDPOINT>
DONATION_DB_PASSWORD=<DONATION_DB_PASSWORD>

# --- donation-service (SQS) ---
# terraform output -raw sqs_queue_url
# Não é segredo de verdade (é só uma URL), mas fica junto no mesmo Secret
# por conveniência — é o único valor do donation-service que só existe
# depois do `terraform apply` (não dá pra hardcodar no deployment.yaml).
AWS_SQS_URL=<AWS_SQS_URL>

# --- volunteer-service ---
# Não tem .env aqui de propósito: não usa senha de banco (DynamoDB) e não
# usa AWS_ACCESS_KEY_ID/SECRET — no AWS Academy, os pods herdam a LabRole
# do node via IMDS (ver hackathon-DCLT/k8s/README.md). Diferente do
# togglemaster-gitops, este repo NÃO guarda nenhuma credencial AWS
# estática em Secret nenhum.

# --- Observabilidade (namespace monitoring) ---
# API key do Datadog (Organization Settings > API Keys). Usada pelo
# otel-collector (monitoring/otel-collector.yaml) pra exportar
# traces/metrics/logs.
DATADOG_API_KEY=<DATADOG_API_KEY>
